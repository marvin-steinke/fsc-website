---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Training – FSC Berlin e.V.">
  <div class="container section">
    <div class="page-content">

      <h2>Trainingszeiten</h2>
      <table class="table-schedule">
        <tbody>
          <tr>
            <td></td>
            <td>Mittwoch</td>
            <td>Freitag</td>
          </tr>
          <tr>
            <td>Kinder (7–11 J.)</td>
            <td colspan="2">17:00 – 18:30</td>
          </tr>
          <tr>
            <td>Jugendliche (12–15 J.)</td>
            <td colspan="2">18:30 – 20:00</td>
          </tr>
          <tr>
            <td>Erwachsene (ab 16 J.)</td>
            <td>–</td>
            <td>20:00 – 21:30</td>
          </tr>
        </tbody>
      </table>

      <hr />

      <div class="section">
        <h2>Trainingsstätte</h2>
        <img
          src="/resources/hgs.jpg"
          class="facility-img"
          alt="Halle der Hausotter-Grundschule"
        />
        <p class="facility-address">
          <strong>Halle der Hausotter-Grundschule</strong><br />
          Hoppestraße 1–6<br />
          13409 Berlin (Alt-Reinickendorf)<br />
          <em>(Eingang über den Hof)</em>
        </p>
      </div>

      <hr />

      <div class="section training-cols">
        <div id="Probetraining">
          <h2>Probetraining</h2>
          <p>
            Ein vierwöchiges Probetraining ist kostenlos und unverbindlich. Jeder kann
            vorbeikommen und zu den oben angegebenen Zeiten mittrainieren. Bei Interesse
            bitten wir, uns kurz über
            <a href="mailto:info@fechtsport-club-berlin.de"
              >info@fechtsport-club-berlin.de</a
            > zu benachrichtigen.
          </p>
        </div>

        <div>
          <h2>AGs</h2>
          <p>
            Wir arbeiten mit Berliner Schulen in Reinickendorf zusammen und bieten dort
            Arbeitsgemeinschaften an:
          </p>
          <ul>
            <li>
              <a
                href="https://goo.gl/maps/Lt4FDxy3YY9wKbRC6"
                target="_blank"
                rel="noopener noreferrer">Renée-Sintenis-Grundschule</a
              >
            </li>
            <li>
              <a
                href="https://goo.gl/maps/susUZHxnHfNcZFYv6"
                target="_blank"
                rel="noopener noreferrer">Hoffman-von-Fallersleben-Grundschule</a
              >
            </li>
            <li>
              <a
                href="https://goo.gl/maps/z8EBoHa5JNZo4LWUA"
                target="_blank"
                rel="noopener noreferrer">Friedrich-Engels-Gymnasium</a
              >
            </li>
          </ul>
          <p>Trainingszeiten nur auf Anfrage!</p>
        </div>
      </div>

    </div>
  </div>
</Layout>
